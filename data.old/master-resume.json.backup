    "experience": {
      "title": "Professional Experience",
      "columns": 1,
      "hidden": false,
      "items": [
        {
          "id": "c67b462d-3270-4e81-9aa7-516e9d600b58",
          "hidden": false,
          "company": "Covai Labs",
          "position": "Principal Product Consultant",
          "location": "Coimbatore, India",
          "period": "August 2023 - Present",
          "website": {
            "url": "https://covai.org",
            "label": ""
          },
          "description": "<p><em>Spearheaded technical strategy and AI product modernization for <a href='https://updates.skyvera.com/authors/jay/'>Skyvera</a> (US telecom client) and other independent engagements.</em></p><ul><li><strong>Legacy Transformation:</strong> Consolidated 11 fragmented software versions into a single unified platform, reducing technical debt and engineering maintenance overhead by <strong>85%</strong>.</li><li><strong>Database Modernization:</strong> Led a strategic migration from Oracle to PostgreSQL, eliminating <strong>$2M+ in annual licensing costs</strong> while maintaining 99.9% uptime.</li><li><strong>AI-Native Product Launch:</strong> Architected and launched AI-native products (<em>Kandy Notetaker</em> for meeting intelligence & <em>Lithium Defender</em> for spam detection), extending legacy UCaaS lifecycles and opening new revenue streams.</li><li><strong>Accelerated Time-to-Market:</strong> Built functional LLM prototypes (Claude Code, Cursor), reducing engineering discovery time by <strong>60%</strong> and accelerating adoption by 3x.</li><li><strong>Customer Experience:</strong> Designed self-service portals with embedded RAG AI agents, automating release note distribution and deflecting support tickets.</li><li><strong>Cross-Functional Leadership:</strong> Operated as central technical liaison between engineering, DevOps, commercial, and customer support teams, authoring API specifications that prioritized scalability and backward compatibility.</li><li><strong>MVP Delivery (Independent Contracts):</strong> Managed two MVP products end-to-end \u2014 a <strong>Live Shopping</strong> app and a <strong>Garage Management Portal</strong> \u2014 defining technical architecture (React.js, Node.js) and API specifications for rapid market entry.</li></ul>",
          "roles": []
        },
        {
          "id": "0c47bf61-6215-4dd3-a944-43a072483c2b",
          "hidden": false,
          "company": "Taxilla IT Solutions",
          "position": "Product Manager",
          "location": "Hyderabad, India",
          "period": "July 2021 - July 2023",
          "website": {
            "url": "",
            "label": ""
          },
          "description": "<p><em>Owned the product lifecycle for a RegTech SaaS platform, driving international expansion and compliance.</em></p><ul><li><strong>RegTech Strategy & Global Expansion:</strong> Led the product roadmap for entering stringent international markets (KSA, UAE), ensuring the platform met complex data sovereignty and cryptographic signing requirements.</li><li><strong>Platform Scalability:</strong> Collaborated with architects to redesign a core high-throughput transaction engine for reconciliation across <strong>Banking, Insurance, and E-commerce</strong>, supporting a <strong>350% increase</strong> in volume.</li><li><strong>Customer Success & MVP:</strong> Built MVP solutions for each industry use-case, personally conducting capability demos for prospective leads and onboarding key accounts for initial <strong>User Acceptance Testing (UAT)</strong>.</li><li><strong>User Adoption & Growth:</strong> Achieved an <strong>80% increase in platform adoption</strong> and a <strong>350% increase in web traffic</strong> by conducting user research to identify friction points and redesigning the onboarding flow.</li></ul>",
          "roles": []
        },
        {
          "id": "d5a11163-1535-41cd-afa5-c16f378e6a80",
          "hidden": false,
          "company": "ValueLabs",
          "position": "Growth Product Manager",
          "location": "Hyderabad, India",
          "period": "April 2019 - January 2021",
          "website": {
            "url": "",
            "label": ""
          },
          "description": "<ul><li><strong>New Product Development:</strong> Led a zero-to-one digital transformation initiative, validating the concept through pilots and securing <strong>3 enterprise contracts</strong> before General Availability (GA).</li><li><strong>Conversion Optimization:</strong> Partnered with design and engineering to implement ML-driven user flows, resulting in a <strong>10% increase in conversion rates</strong> for client platforms.</li></ul>",
          "roles": []
        },
        {
          "id": "c8e46ed0-cc14-4e84-aed1-43d43b9a87bf",
          "hidden": false,
          "company": "IBM",
          "position": "Senior Consultant",
          "location": "Bangalore, India",
          "period": "August 2015 - June 2017",
          "website": {
            "url": "",
            "label": ""
          },
          "description": "<ul><li><strong>Process Automation:</strong> Developed and deployed Python/Bash automation scripts that reduced service desk ticket resolution time by <strong>30%</strong>, directly improving SLA adherence.</li><li><strong>Knowledge Management:</strong> Architected a centralized knowledge repository for the team, streamlining daily operations and reducing onboarding time by <strong>40%</strong>.</li></ul>",
          "roles": []
        },
        {
          "id": "37379546-5353-4b59-bca8-41af3bab0944",
          "hidden": false,
          "company": "LightMass",
          "position": "Senior Manager",
          "location": "Bangalore, India",
          "period": "January 2014 - July 2015",
          "website": {
            "url": "",
            "label": ""
          },
          "description": "<ul><li><strong>Open Source Infrastructure Initiative:</strong> Executed a company-wide migration from unlicensed Windows environments to <strong>CentOS Linux</strong> and <strong>LibreOffice</strong>, saving <strong>$50k+ in licensing fees</strong> and eliminating legal compliance risk.</li><li><strong>Performance Leadership:</strong> Managed a team of 18 agents, improving Service Level Agreement (SLA) delivery by <strong>35%</strong> through rigorous data-driven performance metrics.</li></ul>",
          "roles": []
        },
        {
          "id": "ca7ae081-18ed-489c-ac68-e6f352632303",
          "hidden": false,
          "company": "Sutherland",
          "position": "Consultant",
          "location": "Kochi, India",
          "period": "June 2012 - September 2013",
          "website": {
            "url": "",
            "label": ""
          },
          "description": "<ul><li><strong>Security Specialization:</strong> Diagnosed and removed complex rootkits and ransomware from compromised Windows endpoints, gathering critical threat signature data to refine McAfee's detection algorithms.</li><li><strong>Performance Excellence:</strong> Exceeded performance targets by <strong>120%</strong> for a major U.S. credit bureau client, maintaining high customer retention rates.</li></ul>",
          "roles": []
        }
      ]
    },
